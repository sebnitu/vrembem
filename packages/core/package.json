{
  "name": "@vrembem/core",
  "description": "Provides a number of Sass and JavaScript modules that make up the shared systems and configurations of the Vrembem library.",
  "version": "4.0.0-next.45",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "BEM",
    "front-end",
    "component",
    "core"
  ],
  "style": "./dist/index.css",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "sass": "./index.scss",
      "style": "./dist/index.css",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./layers": {
      "sass": "./layers.scss",
      "style": "./dist/layers.css",
      "default": "./layers.scss"
    },
    "./tokens": {
      "sass": "./src/scss/modules/_tokens.scss",
      "style": "./dist/tokens.css",
      "default": "./src/scss/modules/_tokens.scss"
    },
    "./base": {
      "sass": "./base.scss",
      "style": "./dist/base.css",
      "default": "./base.scss"
    },
    "./config": "./src/scss/modules/_config.scss",
    "./palette": "./src/scss/modules/_palette.scss",
    "./breakpoints": "./src/scss/modules/_breakpoints.scss",
    "./themes": "./src/scss/modules/_themes.scss",
    "./dev/*": "./dev/*",
    "./dist/*": "./dist/*",
    "./*": "./src/*"
  },
  "files": [
    "dev",
    "dist",
    "src",
    "index.ts",
    "index.scss",
    "layers.scss",
    "base.scss",
    "config.scss",
    "tokens.scss",
    "palette.scss",
    "breakpoints.scss",
    "themes.scss"
  ],
  "scripts": {
    "serve": "vite",
    "build": "npm-run-all clean styles scripts",
    "clean": "del dev && del dist",
    "scripts": "npm-run-all scripts:dev scripts:dist scripts:types",
    "scripts:dev": "vite build --outDir dev --minify false",
    "scripts:dist": "vite build --outDir dist",
    "scripts:types": "tsc --project tsconfig.build.json",
    "styles": "npm-run-all styles:dev styles:dist",
    "styles:dev": "sass build:dev --load-path=../../node_modules",
    "styles:dist": "sass build:dist --load-path=../../node_modules --style=compressed",
    "watch": "concurrently --kill-others 'npm run watch:scripts' 'npm run watch:styles'",
    "watch:scripts": "npm run scripts:dev -- --watch",
    "watch:styles": "npm run styles:dev -- --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebnitu/vrembem.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/sebnitu/vrembem/tree/main/packages/core#readme",
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "d966f513f86f66dddf93ed60ddefe51124562dc0"
}
