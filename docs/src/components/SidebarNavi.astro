---
import { buildNaviFromConfig, type NaviConfig } from "@/modules/navigation";
import SidebarNaviMenu from "@/components/SidebarNaviMenu.astro";
import SidebarState from "@/components/SidebarState.astro";

interface Props {
  config: NaviConfig[];
}

const { config } = Astro.props;

const navi = await buildNaviFromConfig(config, Astro.url.pathname);
---

<SidebarState>
  <SidebarNaviMenu tree={navi} />
</SidebarState>
