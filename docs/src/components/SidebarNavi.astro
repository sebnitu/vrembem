---
import type { NaviConfig } from "@/navi.config";
import { resolveNavi } from "@/modules/resolveNavi";
import SidebarNaviMenu from "@/components/SidebarNaviMenu.astro";

interface Props {
  config: NaviConfig[];
}

const { config } = Astro.props;

const items = await resolveNavi(config, Astro.url.pathname);
---

<SidebarNaviMenu {items} />
