---
import { buildNaviTree, type NaviConfig } from "@/helpers/buildNaviTree";
import SidebarNaviMenu from "@/components/SidebarNaviMenu.astro";
import SidebarState from "@/components/SidebarState.astro";

interface Props {
  config: NaviConfig[];
}

const { config } = Astro.props;

const navi = await buildNaviTree(config, Astro.url.pathname);
---

<SidebarState>
  <SidebarNaviMenu tree={navi} />
</SidebarState>
