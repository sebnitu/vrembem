---
import { buildNaviTree, type NaviConfig } from "@/modules/buildNaviTree";
import SidebarNaviMenu from "@/components/SidebarNaviMenu.astro";

interface Props {
  config: NaviConfig[];
}

const { config } = Astro.props;

const navi = await buildNaviTree(config, Astro.url.pathname);

// TODO: Add persistent state for which details are toggled
// TODO: Add persistent state for scroll position
---

<SidebarNaviMenu tree={navi} />
