---
import ThemeSwitcherPopover from "@/components/ThemeSwitcherPopover.astro";
import ThemeSwitcherMenu from "@/components/ThemeSwitcherMenu.astro";
import Icon from "@/components/Icon.astro";

interface Props {
  classes?: string;
  inline?: boolean;
}

const { classes = "", inline = false } = Astro.props;

function actionClasses(path: string) {
  const classes = ["menu__action"];
  const pathname = Astro.url.pathname;
  if (pathname === path || pathname.startsWith(path)) classes.push("is-active");
  return classes.join(" ");
}
---

<ul class={`menu ${inline ? "menu_inline" : ""} ${classes}`.trim()}>
  <li class="menu__item">
    <a class={actionClasses("/guide")} href="/guide">Guide</a>
  </li>
  <li class="menu__item">
    <a class={actionClasses("/packages")} href="/packages/vrembem">Packages</a>
  </li>
  <li class="menu__item">
    <a
      class="menu__action gap-x-xs"
      href="https://github.com/sebnitu/vrembem"
      target="_blank"
    >
      GitHub
      <Icon name="arrow-up-right" classes="icon_external" />
    </a>
  </li>
  <li class="menu__item">
    <a class="menu__action gap-x-xs" href="#" target="_blank">
      Sponsor
      <Icon name="arrow-up-right" classes="icon_external" />
    </a>
  </li>
  {
    inline && (
      <li class={"menu__item margin-left"}>
        <ThemeSwitcherPopover />
      </li>
    )
  }
  {
    !inline && (
      <>
        <li class="menu__sep" />
        <li class="menu__item padding-x padding-y-sm font-weight-semi-bold">
          Switch Theme
        </li>
        <li class="menu__item">
          <ThemeSwitcherMenu />
        </li>
      </>
    )
  }
</ul>
