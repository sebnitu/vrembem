---
import Icon from "@/components/Icon.astro";
---

<ul class="menu">
  <li class="menu__item">
    <button type="button" data-set-mode="auto" class="menu__action">
      <svg
        class="icon"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <circle cx="12" cy="12" r="9" stroke="currentcolor" stroke-width="1.75"
        ></circle>
        <path
          d="M3 12C3 16.9706 7.02944 21 12 21V3C7.02944 3 3 7.02944 3 12Z"
          fill="currentcolor"></path>
      </svg>
      <span>OS Default</span>
    </button>
  </li>
  <li class="menu__item">
    <button type="button" data-set-mode="light" class="menu__action">
      <Icon name="sun" />
      <span>Light</span>
    </button>
  </li>
  <li class="menu__item">
    <button type="button" data-set-mode="dark" class="menu__action">
      <Icon name="moon" />
      <span>Dark</span>
    </button>
  </li>
  <li class="menu__sep"></li>
  <li class="menu__item">
    <button type="button" data-set-theme="default" class="menu__action">
      <Icon name="coffee" />
      <span>Fresh</span>
    </button>
  </li>
  <li class="menu__item">
    <button type="button" data-set-theme="forest" class="menu__action">
      <Icon name="feather" />
      <span>Forest</span>
    </button>
  </li>
  <li class="menu__item">
    <button type="button" data-set-theme="ocean" class="menu__action">
      <Icon name="droplet" />
      <span>Ocean</span>
    </button>
  </li>
</ul>

<script>
  import { themeStore, type ThemeStoreAPI } from "@vrembem/core";
  import { popovers } from "../modules/usePopover";

  const btns: NodeListOf<HTMLButtonElement> = document.querySelectorAll(
    "[data-set-mode], [data-set-theme]"
  );

  themeStore({
    modes: ["auto", "light", "dark"],
    themes: ["default", "forest", "ocean"],
    onInit(store) {
      btns.forEach((btn) => {
        const mode = btn.getAttribute("data-set-mode");
        const theme = btn.getAttribute("data-set-theme");
        btn.classList.toggle("is-active", isActive(mode, theme, store));
        btn.addEventListener("click", () => {
          if (mode) store.mode = mode;
          if (theme) store.theme = theme;
          popovers.close("popover-theme-switcher");
        });
      });
    },
    onChange(store) {
      btns.forEach((btn) => {
        const mode = btn.getAttribute("data-set-mode");
        const theme = btn.getAttribute("data-set-theme");
        btn.classList.toggle("is-active", isActive(mode, theme, store));
      });
    }
  });

  function isActive(
    mode: string | null,
    theme: string | null,
    store: ThemeStoreAPI
  ) {
    const value = mode || theme;
    const base = mode ? "auto" : "default";
    const current = mode ? store.mode : store.theme;
    return !!(value && (value === current || (value === base && !current)));
  }
</script>
