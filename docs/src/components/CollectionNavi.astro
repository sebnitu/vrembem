---
import type { CollectionEntry } from "astro:content";
import { currentPage } from "../modules/currentPage";
import Icon from "./Icon.astro";
import Popover from "../components/Popover.astro";

interface Props {
  entries: CollectionEntry<"packages">[];
  collection: string;
  modules?: CollectionEntry<"modules">[];
  menuClass?: string;
}

const { entries, collection, modules = [], menuClass = "" } = Astro.props;
const title = collection.charAt(0).toUpperCase() + collection.slice(1);
const cp = currentPage(Astro.url.pathname, {
  classBase: "menu__action",
  classCurrent: "is-active"
});

const hasModules = modules.length && modules[0].data.parent;

const categoryIcons = {
  core: "settings",
  modules: "layers",
  "form-control": "check-circle",
  component: "box"
};

function getIconName(string: string) {
  return categoryIcons[string] ? categoryIcons[string] : string;
}
---

<nav>
  <h2 class="sr-only">{title}</h2>
  <ul class={`menu menu_collection ${menuClass}`.trim()}>
    {
      entries.map((entry) => (
        <li class="menu__item">
          <a
            class={cp.classes(`/${collection}/${entry.id}`)}
            href={`/${collection}/${entry.id}`}
          >
            <span class="flex-grow">{entry.data.title}</span>
            {entry.data.category && (
              <Popover placement="left" triggerClass="display-flex">
                <Fragment slot="trigger">
                  <Icon
                    name={getIconName(entry.data.category)}
                    classes="icon_size_sm foreground-primary"
                  />
                </Fragment>
                <Fragment slot="tooltip">{entry.data.category}</Fragment>
              </Popover>
            )}
          </a>
          {hasModules === entry.id && (
            <ul class="menu menu_size_sm margin-left margin-y-sm">
              {modules.map((item) => (
                <li class="menu__item">
                  <a class="menu__action" href={`/${collection}/${item.id}`}>
                    {item.data.title}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
  </ul>
</nav>
