---
import type { ResolvedNaviItem } from "@/navi.config";

interface Props {
  items: ResolvedNaviItem[];
  nested?: boolean;
}

const { items, nested } = Astro.props;
---

<ul class={`menu ${nested ? "menu_collection" : ""}`.trim()}>
  {
    items.map((item) =>
      "items" in item ? (
        <li class="menu__item">
          <details open>
            <summary>
              <span>{item.label}</span>
              <span class="spacer" />
              <span class="caret" />
            </summary>
            <Astro.self items={item.items} nested />
          </details>
        </li>
      ) : (
        <li class="menu__item">
          <a
            class:list={[
              "menu__action",
              { "is-active": item.isCurrent, "is-parent": item.isParent }
            ]}
            href={item.link}
          >
            {item.label}
          </a>
        </li>
      )
    )
  }
</ul>

<style lang="scss">
  @use "@vrembem/core";
  @use "@vrembem/core/tokens";

  summary {
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75em;
    padding: tokens.get("form-control-padding-y") 0;
    color: tokens.get("foreground-strong");
    font-weight: tokens.get("font-weight-bold");

    .spacer {
      height: 1px;
      flex-grow: 1;
      background-color: tokens.get("border-color");
    }

    .caret {
      @include core.size(0.8em);
      position: relative;
      inset: 0;
      display: block;
      background-color: currentcolor;
      mask: url(core.svg("chevron")) center / 100% no-repeat;
      transition: transform tokens.get("transition-short");
      transform: rotate(-90deg);

      details[open] & {
        transform: rotate(0);
      }
    }
  }
</style>
