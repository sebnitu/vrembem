---
import type { NaviItem, NaviLink } from "@/modules/buildNaviTree";

interface Props {
  tree: NaviItem[];
  nested?: boolean;
}

const { tree, nested } = Astro.props;

function classes(entry: NaviLink) {
  return { "is-active": entry.isCurrent, "is-parent": entry.isParent };
}
---

<ul class={`menu ${nested ? "menu_collection" : ""}`.trim()}>
  {
    tree.map((entry) =>
      "link" in entry ? (
        <li class="menu__item">
          <a class:list={["menu__action", classes(entry)]} href={entry.link}>
            {entry.label}
          </a>
        </li>
      ) : (
        <li class="menu__item">
          <details open>
            <summary>
              <span>{entry.label}</span>
              <span class="spacer" />
              <span class="caret" />
            </summary>
            <vb-sidebar-group />
            <Astro.self tree={entry.group} nested />
          </details>
        </li>
      )
    )
  }
</ul>

<style lang="scss">
  @use "@vrembem/core";
  @use "@vrembem/core/tokens";

  summary {
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75em;
    padding: tokens.get("form-control-padding-y") 0;
    color: tokens.get("foreground-strong");
    font-weight: tokens.get("font-weight-bold");

    .spacer {
      height: 1px;
      flex-grow: 1;
      background-color: tokens.get("border-color");
    }

    .caret {
      @include core.size(0.8em);
      position: relative;
      inset: 0;
      display: block;
      background-color: currentcolor;
      mask: url(core.svg("chevron")) center / 100% no-repeat;
      transition: transform tokens.get("transition-short");
      transform: rotate(-90deg);

      details[open] & {
        transform: rotate(0);
      }
    }
  }
</style>
