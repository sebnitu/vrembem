---
import Icon from "@/components/Icon.astro";
import Popover from "@/components/Popover.astro";
import ThemeSwitcherMenu from "@/components/ThemeSwitcherMenu.astro";
---

<Popover
  id="theme-switcher"
  aria-label="Switch selected theme"
  triggerClass="button button--icon form-control-size overflow-hidden"
  popoverClass="popover--size-auto vb-theme-light"
  placement="bottom-end"
>
  <Fragment slot="trigger">
    <svg
      class="icon theme-icon theme-icon--auto"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <circle cx="12" cy="12" r="9" stroke="currentcolor" stroke-width="1.75"
      ></circle>
      <path
        d="M3 12C3 16.9706 7.02944 21 12 21V3C7.02944 3 3 7.02944 3 12Z"
        fill="currentcolor"></path>
    </svg>
    <Icon name="sun" classes="theme-icon theme-icon--light" />
    <Icon name="moon" classes="theme-icon theme-icon--dark" />
  </Fragment>
  <Fragment slot="tooltip">Switch theme</Fragment>
  <ThemeSwitcherMenu />
</Popover>
