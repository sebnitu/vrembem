---
import fs from "node:fs";
import path from "node:path";
import { Code } from "astro:components";
import CodeBlock from "@/components/CodeBlock.astro";
import Tabs from "@/components/Tabs.astro";

interface FileTab {
  name: string;
  content: string;
}

interface Props {
  label?: string;
  lang?: string;
  tabs?: boolean;
  syncKey?: string;
  iframe?: string;
  style?: string;
  files?: FileTab[];
  flush?: boolean;
  resettable?: boolean;
}

const {
  label,
  iframe,
  style,
  lang = "html",
  tabs = false,
  syncKey,
  files = [],
  flush = false,
  resettable = false
} = Astro.props;

const uid = JSON.stringify(Math.floor(Math.random() * Date.now()));

const iframeCode = iframe
  ? fs.readFileSync(path.join(process.cwd(), "public", iframe), "utf-8")
  : "";
---

<div class="code-example" {style}>
  {
    !tabs && (
      <div class="code-example__toolbar">
        <div class="flex-grow">{label || lang?.toUpperCase()}</div>
        {resettable && (
          <button
            type="button"
            class="link"
            data-reset={`code-example-output-${uid}`}
          >
            Reset <span class="sr-only">example</span>
          </button>
        )}
      </div>
    )
  }
  {
    iframe && (
      <div class="code-example__output">
        <iframe src={iframe} />
      </div>
      <div class="code-example__input">
        <CodeBlock nopre>
          <Code
            code={iframeCode}
            lang="html"
            theme="css-variables"
            class="pre"
          />
        </CodeBlock>
      </div>
    )
  }
  {
    tabs && (
      <Tabs {syncKey} {label}>
        <slot />
      </Tabs>
    )
  }
  {
    Astro.slots.has("demo") && (
      <div class="code-example__demo">
        <slot name="demo" />
      </div>
    )
  }
  {
    Astro.slots.has("output") && (
      <div id={`code-example-output-${uid}`} class="code-example__output">
        <div class={`code-example__inner ${flush ? "padding-0" : ""}`.trim()}>
          <slot name="output" />
        </div>
      </div>
    )
  }
  {
    !tabs && Astro.slots.has("default") && (
      <div class="code-example__input">
        <slot />
      </div>
    )
  }
  {
    files.map((file: FileTab, i: number) => (
      <div
        class="code-example__input"
        id={`tabpanel-${i}-${uid}`}
        role="tabpanel"
        aria-labelledby={`tab-${i}-${uid}`}
      >
        <CodeBlock nopre>
          <Code
            code={file.content}
            lang="js"
            theme="css-variables"
            class="pre"
          />
        </CodeBlock>
      </div>
    ))
  }
</div>
