{
  "--vb-base-background": "var(--vb-background)",
  "--vb-base-foreground": "var(--vb-foreground)",

  "--vb-headings-foreground": "var(--vb-foreground-strong)",
  "--vb-headings-font-family": "inherit",
  "--vb-headings-font-weight": "var(--vb-font-weight-semi-bold)",
  "--vb-headings-line-height": "inherit",

  "--vb-link-foreground": "var(--vb-foreground-accent)",
  "--vb-link-foreground-hover": "light-dark(oklch(from var(--vb-foreground-accent) calc(l - 0.1) c h), var(--vb-foreground-accent) calc(l + 0.1) c h)))",
  "--vb-link-decoration": "underline",
  "--vb-link-decoration-hover": "none",
  "--vb-link-decoration-thickness": "1px",
  "--vb-link-underline-offset": "2px",
  "--vb-link-focus-ring": "currentcolor dotted 1px",
  "--vb-link-focus-ring-offset": "0.125rem",

  "--vb-list-indent": "var(--vb-spacing-lg)",
  "--vb-list-spacing": "var(--vb-spacing-sm)",

  "--vb-code-background": "var(--vb-background-alt)",
  "--vb-code-foreground": "var(--vb-foreground-accent-alt)",
  "--vb-code-border": "var(--vb-border)",
  "--vb-code-border-radius": "var(--vb-border-radius)",
  "--vb-code-font-size": "var(--vb-font-size-sm)",
  "--vb-code-padding": "0.125rem 0.375rem",

  "--vb-pre-background": "var(--vb-background-alt)",
  "--vb-pre-foreground": "var(--vb-foreground-strong)",
  "--vb-pre-border": "none",
  "--vb-pre-border-radius": "var(--vb-border-radius)",
  "--vb-pre-padding": "var(--vb-spacing-md)",
  "--vb-pre-font-size": "var(--vb-font-size-sm)",

  "--vb-blockquote-background": "transparent",
  "--vb-blockquote-foreground": "currentcolor",
  "--vb-blockquote-border": "var(--vb-border)",
  "--vb-blockquote-border-radius": "var(--vb-border-radius)",
  "--vb-blockquote-padding": "var(--vb-spacing-md)",
  "--vb-blockquote-spacing": "var(--vb-spacing-md)",

  "--vb-separator-border-width": "var(--vb-border-width)",
  "--vb-separator-border-style": "var(--vb-border-style)",
  "--vb-separator-border-color": "var(--vb-border-color)",

  "--vb-type-foreground": "var(--vb-foreground)",
  "--vb-type-font-family": "inherit",
  "--vb-type-font-size": "inherit",
  "--vb-type-line-height": "inherit",
  "--vb-type-spacing": "",

  "--vb-arrow-size": "6px 4px",
  "--vb-arrow-color": "currentcolor",
  "--vb-arrow-radius": "2px",

  "--vb-loading-size": "1em",
  "--vb-loading-duration": "0.6s",
  "--vb-loading-border": "2px solid",
  "--vb-loading-color": "currentcolor"
}
