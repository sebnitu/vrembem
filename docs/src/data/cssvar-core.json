{
  "--vb-prefix": "vb",
  "--vb-theme-prefix": "vb-theme",
  "--vb-breakpoint-xs": "480px",
  "--vb-breakpoint-sm": "620px",
  "--vb-breakpoint-md": "760px",
  "--vb-breakpoint-lg": "990px",
  "--vb-breakpoint-xl": "1380px",
  "--vb-backdrop-color": "hsl(var(--vb-neutral-hs) 10%)",
  "--vb-backdrop-opacity": "80%",
  "--vb-spacing": "0.25em",
  "--vb-spacing-xs": "var(--vb-spacing)",
  "--vb-spacing-sm": "calc(var(--vb-spacing) * 2)",
  "--vb-spacing-md": "calc(var(--vb-spacing) * 4)",
  "--vb-spacing-lg": "calc(var(--vb-spacing) * 6)",
  "--vb-spacing-xl": "calc(var(--vb-spacing) * 8)",
  "--vb-border-width": "1px",
  "--vb-border-style": "solid",
  "--vb-border": "var(--vb-border-width) var(--vb-border-style) var(--vb-border-color)",
  "--vb-border-dark": "var(--vb-border-width) var(--vb-border-style) var(--vb-border-color-dark)",
  "--vb-border-darker": "var(--vb-border-width) var(--vb-border-style) var(--vb-border-color-darker)",
  "--vb-border-radius": "0.25rem",
  "--vb-border-radius-lg": "0.5rem",
  "--vb-border-radius-circle": "9999px",
  "--vb-box-shadow": "0 2px 6px var(--vb-shadow-color)",
  "--vb-box-shadow-1": "0 1px 3px var(--vb-shadow-color)",
  "--vb-box-shadow-2": "0 2px 6px var(--vb-shadow-color)",
  "--vb-box-shadow-3": "0 4px 12px var(--vb-shadow-color)",
  "--vb-box-shadow-4": "0 8px 18px var(--vb-shadow-color)",
  "--vb-box-shadow-5": "0 12px 24px var(--vb-shadow-color)",
  "--vb-font-family": "var(--vb-font-family-sans)",
  "--vb-font-family-sans": "blinkmacsystemfont, -apple-system, system-ui, Segoe UI, Roboto, Helvetica Neue, arial, sans-serif",
  "--vb-font-family-serif": "constantia, Lucida Bright, lucidabright, Lucida Serif, lucida, DejaVu Serif, Bitstream Vera Serif, Liberation Serif, georgia, serif",
  "--vb-font-family-mono": "sfmono-regular, menlo, monaco, consolas, Liberation Mono, Courier New, monospace",
  "--vb-font-size": "1rem",
  "--vb-font-size-sm": "0.875rem",
  "--vb-font-size-lg": "1.125rem",
  "--vb-line-height": "1.5",
  "--vb-font-weight-thin": "100",
  "--vb-font-weight-extra-light": "200",
  "--vb-font-weight-light": "300",
  "--vb-font-weight-regular": "400",
  "--vb-font-weight-medium": "500",
  "--vb-font-weight-semi-bold": "600",
  "--vb-font-weight-bold": "700",
  "--vb-font-weight-extra-bold": "800",
  "--vb-font-weight-black": "900",
  "--vb-transition-duration": "0.3s",
  "--vb-transition-duration-short": "0.15s",
  "--vb-transition-duration-long": "0.6s",
  "--vb-transition-timing-function": "cubic-bezier(0.4, 0, 0.2, 1)",
  "--vb-transition": "var(--vb-transition-duration) var(--vb-transition-timing-function)",
  "--vb-transition-short": "var(--vb-transition-duration-short) var(--vb-transition-timing-function)",
  "--vb-transition-long": "var(--vb-transition-duration-long) var(--vb-transition-timing-function)",
  "--vb-focus-ring-width": "3px",
  "--vb-focus-ring-style": "solid",
  "--vb-focus-ring-offset": "0",
  "--vb-focus-ring-color": "var(--vb-primary)",
  "--vb-focus-ring-opacity": "40%",
  "--vb-form-control-size": "var(--vb-font-size)",
  "--vb-form-control-size-sm": "var(--vb-font-size-sm)",
  "--vb-form-control-size-lg": "var(--vb-font-size-lg)",
  "--vb-form-control-line-height": "var(--vb-line-height)",
  "--vb-form-control-border-width": "var(--vb-border-width)",
  "--vb-form-control-border-radius": "var(--vb-border-radius)",
  "--vb-form-control-padding-x": "1em",
  "--vb-form-control-padding-y": "0.5em",
  "--vb-form-control-padding": "var(--vb-form-control-padding-y) var(--vb-form-control-padding-x)",
  "--vb-form-control-size-calc": "calc(1em * var(--vb-form-control-line-height) + (var(--vb-form-control-padding-y) + var(--vb-form-control-border-width)) * 2)",
  "--vb-form-control-accent": "var(--vb-primary)",
  "--vb-form-control-foreground": "var(--vb-foreground)",
  "--vb-form-control-background": "var(--vb-background)",
  "--vb-form-control-background-disabled": "var(--vb-background-darker)",
  "--vb-form-control-background-readonly": "var(--vb-background-darker)",
  "--vb-form-control-opacity-disabled": 0.6,
  "--vb-form-control-choice-color": "var(--vb-foreground-lighter)",
  "--vb-form-control-choice-color-checked": "var(--vb-form-control-accent)",
  "--vb-form-control-choice-background-border-radius": "var(--vb-border-radius-circle)",
  "--vb-form-control-choice-background-opacity": "0%",
  "--vb-form-control-choice-background-opacity-hover": "20%",
  "--vb-form-control-choice-background-opacity-focus": "20%",
  "--vb-form-control-choice-background-opacity-active": "30%",
  "--vb-form-control-transition-property": "box-shadow, outline",
  "--vb-form-control-transition-duration": "var(--vb-transition-duration-short)",
  "--vb-form-control-transition-timing-function": "var(--vb-transition-timing-function)",
  "--vb-primary": "hsl(152, 60%, 50%)",
  "--vb-primary-hs": "152deg 60%",
  "--vb-secondary": "hsl(214, 50%, 50%)",
  "--vb-secondary-hs": "214deg 50%",
  "--vb-neutral": "hsl(214, 20%, 50%)",
  "--vb-neutral-hs": "214deg 20%",
  "--vb-important": "hsl(0, 80%, 50%)",
  "--vb-important-hs": "0deg 80%",
  "--vb-background": {
    "light": "hsl(var(--vb-neutral-hs) 100%)",
    "dark": "hsl(var(--vb-neutral-hs) 10%)"
  },
  "--vb-background-dark": {
    "light": "hsl(var(--vb-neutral-hs) 98%)",
    "dark": "hsl(var(--vb-neutral-hs) 12%)"
  },
  "--vb-background-darker": {
    "light": "hsl(var(--vb-neutral-hs) 95%)",
    "dark": "hsl(var(--vb-neutral-hs) 15%)"
  },
  "--vb-background-alt": {
    "light": "hsl(var(--vb-secondary-hs) 60% / 10%)",
    "dark": "hsl(var(--vb-secondary-hs) 70% / 10%)"
  },
  "--vb-background-hover": {
    "light": "rgba(0, 0, 0, 0.05)",
    "dark": "rgba(255, 255, 255, 0.05)"
  },
  "--vb-background-focus": {
    "light": "rgba(0, 0, 0, 0.05)",
    "dark": "rgba(255, 255, 255, 0.05)"
  },
  "--vb-background-active": {
    "light": "rgba(0, 0, 0, 0.1)",
    "dark": "rgba(255, 255, 255, 0.01)"
  },
  "--vb-foreground": {
    "light": "hsl(var(--vb-neutral-hs) 20%)",
    "dark": "hsl(var(--vb-neutral-hs) 90%)"
  },
  "--vb-foreground-light": {
    "light": "hsl(var(--vb-neutral-hs) 40%)",
    "dark": "hsl(var(--vb-neutral-hs) 70%)"
  },
  "--vb-foreground-lighter": {
    "light": "hsl(var(--vb-neutral-hs) 60%)",
    "dark": "hsl(var(--vb-neutral-hs) 50%)"
  },
  "--vb-foreground-alt": {
    "light": "hsl(var(--vb-secondary-hs) 50%)",
    "dark": "hsl(var(--vb-secondary-hs) 60%)"
  },
  "--vb-border-color": {
    "light": "rgba(0, 0, 0, 0.1)",
    "dark": "rgba(255, 255, 255, 0.1)"
  },
  "--vb-border-color-dark": {
    "light": "rgba(0, 0, 0, 0.2)",
    "dark": "rgba(255, 255, 255, 0.2)"
  },
  "--vb-border-color-darker": {
    "light": "rgba(0, 0, 0, 0.3)",
    "dark": "rgba(255, 255, 255, 0.3)"
  },
  "--vb-shadow-color": {
    "light": "hsl(var(--vb-neutral-hs) 20% / 20%)",
    "dark": "hsl(var(--vb-neutral-hs) 0% / 20%)"
  }
}
