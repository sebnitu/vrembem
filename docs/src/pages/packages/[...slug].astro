---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { getCollectionPath } from "@/helpers/getCollectionPath";
import Page from "@/layouts/Page.astro";
import CodeExample from "@/components/CodeExample.astro";
import Pre from "@/components/Pre.astro";
import Table from "@/components/Table.astro";

interface Props {
  entry: CollectionEntry<"packages"> | CollectionEntry<"modules">;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

export async function getStaticPaths() {
  const packages = await getCollection("packages");
  const modules = await getCollection("modules");

  return [
    ...packages.map((entry) => ({
      params: { slug: entry.id },
      props: { entry }
    })),
    ...modules.map((entry) => {
      return {
        params: { slug: getCollectionPath(entry) },
        props: { entry }
      };
    })
  ];
}
---

<Page {entry} {headings}>
  <Content components={{ CodeExample, pre: Pre, table: Table }} />
</Page>

<script>
  import "../../modules/currentViewport";
  import "../../modules/dismissible";
  import "../../modules/resettable";
  import "../../modules/demo";
  import "../../modules/demos";
</script>
