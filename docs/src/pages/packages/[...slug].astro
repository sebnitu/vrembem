---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { getPackages } from "../../modules/getPackages";
import { getModules } from "../../modules/getModules";
import Base from "../../layouts/Base.astro";
import Intro from "../../components/Intro.astro";
import Navi from "../../components/CollectionNavi.astro";
import Pagi from "../../components/CollectionPagi.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import LinkEditPage from "../../components/LinkEditPage.astro";
import CodeExample from "../../components/CodeExample.astro";
import Pre from "../../components/Pre.astro";
import Table from "../../components/Table.astro";

interface Props {
  entry: CollectionEntry<"packages"> | CollectionEntry<"modules">;
}

const { entry } = Astro.props;

export async function getStaticPaths() {
  const packages = await getPackages();
  const modules = await getModules();

  const entries = [
    ...packages.map((entry) => ({
      params: { slug: entry.id },
      props: { entry }
    })),
    ...modules.map((entry) => ({
      params: { slug: `${entry.data.parent}/${entry.id}` },
      props: { entry }
    }))
  ];

  return entries;
}

const { Content, headings } = await render(entry);

const packages = await getPackages();

let modules: CollectionEntry<"modules">[] = [];
if ("parent" in entry.data) {
  modules = await getModules(entry.data.group);
}

const layout = {
  hasSidebar: true,
  hasAside: true
};
---

<Base title={entry.data.title} {layout}>
  <Fragment slot="sidebar">
    <Navi collection="packages" entries={packages} {modules} />
  </Fragment>
  <Fragment slot="aside">
    <OnThisPage {headings} />
  </Fragment>
  <Intro data={entry.data} />
  <Content components={{ CodeExample, pre: Pre, table: Table }} />
  <div slot="append" class="spacing-xl">
    <LinkEditPage />
    <hr class="sep" />
    {"package" in entry.data && <Pagi entries={packages} />}
    {"parent" in entry.data && <Pagi entries={modules} />}
  </div>
</Base>

<script>
  import "../../modules/currentViewport";
  import "../../modules/dismissible";
  import "../../modules/resettable";
  import "../../modules/demo";
  import "../../modules/demos";
  import { headingAnchor } from "../../modules/headingAnchor";
  import { toggle } from "../../modules/toggle";

  headingAnchor.mount();
  toggle.mount();
</script>
