---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { getPackages } from "../../modules/getPackages";
import { getModules } from "../../modules/getModules";
import { getModuleMeta } from "../../helpers/getModuleMeta";
import Page from "../../layouts/Page.astro";
import CodeExample from "../../components/CodeExample.astro";
import Pre from "../../components/Pre.astro";
import Table from "../../components/Table.astro";

interface Props {
  entry: CollectionEntry<"packages"> | CollectionEntry<"modules">;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

export async function getStaticPaths() {
  const packages = await getPackages();
  const modules = await getModules();

  return [
    ...packages.map((entry) => ({
      params: { slug: entry.id },
      props: { entry }
    })),
    ...modules.map((entry) => {
      const { parent } = getModuleMeta(entry);
      return {
        params: { slug: `${parent}/${entry.id.split("/").pop()}` },
        props: { entry }
      };
    })
  ];
}
---

<Page {entry} {headings}>
  <Content components={{ CodeExample, pre: Pre, table: Table }} />
</Page>

<script>
  import "../../modules/currentViewport";
  import "../../modules/dismissible";
  import "../../modules/resettable";
  import "../../modules/demo";
  import "../../modules/demos";
</script>
